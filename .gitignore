# env files - CRITICAL - never commit these
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
/src/generated/prisma

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
Thumbs.db

# Temporary files
*.log
tmp/
temp/

