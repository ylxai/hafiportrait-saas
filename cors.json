{
  "rules": [
    {
      "allowed": {
        "methods": ["GET", "PUT", "POST", "DELETE", "HEAD"],
        "origins": ["http://localhost:3000", "http://localhost:3001", "http://127.0.0.1:3000", "http://127.0.0.1:3001", "*"],
        "headers": ["*"]
      },
      "exposeHeaders": ["*"],
      "maxAgeSeconds": 3600
    }
  ]
}