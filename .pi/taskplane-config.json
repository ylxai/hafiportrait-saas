{
  "configVersion": 1,
  "taskRunner": {
    "project": {
      "name": "web-saas",
      "description": ""
    },
    "paths": {
      "tasks": "tasks"
    },
    "testing": {
      "commands": {
        "lint": "npm run lint",
        "build": "npm run build"
      }
    },
    "taskAreas": {
      "general": {
        "path": "tasks/general",
        "prefix": "GEN",
        "context": "tasks/general/CONTEXT.md"
      },
      "frontend": {
        "path": "tasks/frontend",
        "prefix": "UI",
        "context": "tasks/frontend/CONTEXT.md"
      },
      "backend": {
        "path": "tasks/backend",
        "prefix": "API",
        "context": "tasks/backend/CONTEXT.md"
      },
      "workers": {
        "path": "tasks/workers",
        "prefix": "WRK",
        "context": "tasks/workers/CONTEXT.md"
      }
    }
  }
}
